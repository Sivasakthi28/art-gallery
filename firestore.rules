rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Updated to support both admin emails
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'admin@elegance.com' || 
        request.auth.token.email == 'admin@varmagallery.com'
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. PRODUCTS (Public read, Admin write)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. USERS & CART (Owner only)
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /cart/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 3. ORDERS (Users can create, Owners can read, Admin can read/write)
    match /orders/{orderId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Normal users can only read their own orders; Admin can read ALL
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
